DATABASE_URL=sqlite:///./roofcinema.db
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SUPER_ADMIN_EMAIL=owner@roofcinema.app
SUPER_ADMIN_PASSWORD=changeme123
SUPER_ADMIN_NAME=Владелец

# Опциональные API-ключи внешних источников фильмов:
# OMDb — https://www.omdbapi.com/apikey.aspx (1000 запросов в день бесплатно, IMDB-данные)
# Kinopoisk Unofficial — https://kinopoiskapiunofficial.tech/ (бесплатный тариф)
OMDB_API_KEY=
KINOPOISK_API_KEY=

# SMTP для отправки писем (подтверждение email, сброс пароля).
# Если оставить SMTP_HOST пустым — письма печатаются в консоль backend (dev-режим).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@roofcinema.app
SMTP_USE_TLS=true
# Базовый URL фронтенда — для ссылок в письмах (сброс пароля и т.п.)
APP_BASE_URL=http://127.0.0.1:5180
